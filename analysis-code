#anova(lm_pc1_type_all)

# Same for top200
lm_pc1_top200 <- lm(PC1 ~ status_of_disease, data = pca_scores_top200)
anova(lm_pc1_top200)
summary(lm_pc1_top200)

lm_pc2_top200 <- lm(PC2 ~ status_of_disease, data = pca_scores_top200)
anova(lm_pc2_top200)
summary(lm_pc2_top200)

# biplot
biplot(pca_all)
biplot(pca_top200)

# Step 8: Fixed clustering on PCA scores 
# For all sig genes
pc_data_cluster_all <- pca_scores_all[, c("PC1", "PC2", "PC3", "PC4", "PC5")]  # Numeric PCs only; adjust as needed
dist_matrix_all <- dist(pc_data_cluster_all)
hclust_all <- hclust(dist_matrix_all, method = "ward.D2")
plot(hclust_all)
clusters_all <- cutree(hclust_all, k = 4)  # Adjust k based on dendrogram

# For top200
pc_data_cluster_top200 <- pca_scores_top200[, c("PC1", "PC2", "PC3", "PC4", "PC5")]
dist_matrix_top <- dist(pc_data_cluster_top200)
hclust_top <- hclust(dist_matrix_top, method = "ward.D2")
plot(hclust_top)
clusters_top <- cutree(hclust_top, k = 4)

# Optional: Add clusters back to scores for summary
pca_scores_top200$cluster <- clusters_top
table(pca_scores_top200$cluster, pca_scores_top200$status_of_disease)


# kmeans
kmeans_all <- kmeans(pc_data_cluster_all, centers = 4)
table(kmeans_all$cluster, pca_scores_all$status_of_disease)

